[user]
	name = Benny-Gil
	email = benny.gil999@gmail.com

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[init]
	defaultBranch = main

[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	autocrlf = input
	pager = less -FRX

[color]
	ui = auto

[pull]
	rebase = true

[push]
	default = current
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	autoStash = true

# zdiff3 needs git >= 2.35, autocorrect=prompt needs >= 2.40
# (Ubuntu 22.04 ships 2.34 — change these to diff3 / 0 there)
[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default
	algorithm = histogram

[branch]
	sort = -committerdate

[help]
	autocorrect = prompt

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	cm = commit -m
	amend = commit --amend --no-edit
	unstage = reset HEAD --
	last = log -1 HEAD
	lg = log --oneline --graph --decorate --all
	undo = reset --soft HEAD~1
	aliases = config --get-regexp ^alias\\.

# Machine-specific overrides (credential helper, work identity) — untracked.
# A plain include applies everywhere; git silently skips it if the file is missing.
[include]
	path = ~/.gitconfig.local
